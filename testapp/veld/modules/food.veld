// Food module — endpoints for the food API
import @models/food
module Food {
  description: "Food Management API"
  prefix: /food
  action GetAllFoods {
    method: GET
    path: /all
    output: FoodList
  }
  action AddFood {
    method: POST
    path: /
    input: CreateFoodInput
    output: Food
  }
}

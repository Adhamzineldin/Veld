{
  "$schema": "https://veld.dev/schemas/veld.config.schema.json",
  "input": "app.veld",
  "description": "${DESCRIPTION}",

  "backendConfig": {
    "target": "${BACKEND}",
    "out": "../backend/src/generated",
    "dir": "../backend"
  },

  "frontendConfig": {
    "target": "${FRONTEND}",
    "out": "../frontend/src/generated",
    "dir": "../frontend"
  },

  "baseUrl": "",
  "aliases": {}
}

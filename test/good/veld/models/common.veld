// ── FEATURE: all-optional models (for query params) ──
// Shared types — demonstrates query parameter models.

model UserFilters {
  description: "Query parameters for filtering user lists"
  role?:    string
  status?:  string
  search?:  string
  limit?:   int
  offset?:  int
}

model ErrorResponse {
  description: "Standard error envelope"
  code:     int
  message:  string
  details?: string
}

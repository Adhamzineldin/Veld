{
  "version": 1,
  "modules": [
    {
      "name": "Accounts",
      "description": "Bank account management — open, view, freeze, and close accounts",
      "prefix": "/api/accounts",
      "actions": [
        {
          "name": "ListAccounts",
          "description": "List all accounts for the authenticated user",
          "method": "GET",
          "path": "/",
          "input": "",
          "output": "Account",
          "outputArray": true,
          "errors": [
            "Unauthorized"
          ],
          "middleware": [
            "AuthGuard"
          ]
        },
        {
          "name": "GetAccount",
          "description": "Fetch a single account by ID",
          "method": "GET",
          "path": "/:id",
          "input": "",
          "output": "Account",
          "errors": [
            "Unauthorized",
            "NotFound"
          ],
          "middleware": [
            "AuthGuard"
          ]
        },
        {
          "name": "CreateAccount",
          "description": "Open a new checking, savings, or investment account",
          "method": "POST",
          "path": "/",
          "input": "CreateAccountInput",
          "output": "Account",
          "errors": [
            "Unauthorized",
            "BadRequest"
          ],
          "middleware": [
            "AuthGuard"
          ]
        },
        {
          "name": "GetSummary",
          "description": "Portfolio summary — total balance and primary account",
          "method": "GET",
          "path": "/summary",
          "input": "",
          "output": "AccountSummary",
          "errors": [
            "Unauthorized"
          ],
          "middleware": [
            "AuthGuard"
          ]
        },
        {
          "name": "FreezeAccount",
          "description": "Freeze an account to block all future transactions",
          "method": "POST",
          "path": "/:id/freeze",
          "input": "",
          "output": "Account",
          "errors": [
            "Unauthorized",
            "NotFound"
          ],
          "middleware": [
            "AuthGuard"
          ]
        },
        {
          "name": "CloseAccount",
          "description": "Permanently close an account",
          "method": "DELETE",
          "path": "/:id",
          "input": "",
          "output": "",
          "errors": [
            "Unauthorized",
            "NotFound"
          ],
          "middleware": [
            "AuthGuard"
          ]
        },
        {
          "name": "banaccount",
          "method": "POST",
          "path": "/ban",
          "input": "",
          "output": "",
          "errors": [
            "Unauthorized",
            "NotFound"
          ],
          "middleware": []
        }
      ]
    }
  ],
  "models": [
    {
      "name": "Account",
      "description": "A NexusBank financial account",
      "fields": [
        {
          "name": "id",
          "type": "string"
        },
        {
          "name": "userId",
          "type": "string"
        },
        {
          "name": "type",
          "type": "AccountType"
        },
        {
          "name": "status",
          "type": "AccountStatus"
        },
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "currency",
          "type": "string"
        },
        {
          "name": "balance",
          "type": "float"
        },
        {
          "name": "iban",
          "type": "string"
        },
        {
          "name": "createdAt",
          "type": "string"
        }
      ]
    },
    {
      "name": "CreateAccountInput",
      "description": "Payload to open a new bank account",
      "fields": [
        {
          "name": "type",
          "type": "AccountType"
        },
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "currency",
          "type": "string"
        }
      ]
    },
    {
      "name": "AccountSummary",
      "description": "Portfolio overview across all user accounts",
      "fields": [
        {
          "name": "totalBalance",
          "type": "float"
        },
        {
          "name": "accountCount",
          "type": "int"
        },
        {
          "name": "primaryAccount",
          "type": "Account"
        }
      ]
    }
  ]
}